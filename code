// ─── SCREEN: GROUP SETUP ──────────────────────────────────────
function GroupScreen({user, onDone}) {
const [mode, setMode]     = useState(null); // “create” | “join”
const [groupName, setGN]  = useState(””);
const [code, setCode]     = useState(””);
const [err, setErr]       = useState(””);
const [loading, setLoad]  = useState(false);

async function handleCreate() {
if (!groupName.trim()) { setErr(“Gruppenname eingeben”); return; }
setLoad(true); setErr(””);
try {
const inviteCode = Math.random().toString(36).slice(2,8).toUpperCase();
const ref = await addDoc(collection(db,“groups”),{
name: groupName.trim(),
inviteCode,
createdBy: user.uid,
members: [user.uid],
createdAt: serverTimestamp(),
});
await updateDoc(doc(db,“users”,user.uid),{groupId: ref.id});
onDone();
} catch(e){ setErr(e.message); }
setLoad(false);
}

async function handleJoin() {
if (!code.trim()) { setErr(“Code eingeben”); return; }
setLoad(true); setErr(””);
try {
const q = query(collection(db,“groups”), where(“inviteCode”,”==”,code.trim().toUpperCase()));
const snap = await getDocs(q);
if (snap.empty) { setErr(“Kein Gruppe mit diesem Code gefunden”); setLoad(false); return; }
const groupDoc = snap.docs[0];
const members = groupDoc.data().members || [];
if (!members.includes(user.uid)) {
await updateDoc(doc(db,“groups”,groupDoc.id),{members:[…members, user.uid]});
}
await updateDoc(doc(db,“users”,user.uid),{groupId: groupDoc.id});
onDone();
} catch(e){ setErr(e.message); }
setLoad(false);
}

return (
<div style={{minHeight:“100vh”,background:”#050508”,padding:“60px 24px 40px”}}>
