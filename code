function HomeScreen({user, userData, groupData, members, isPremium, onUpgrade, onToast}) {
const [showInput, setShowInput] = useState(false);
const [inputVal, setInputVal]   = useState(””);
const [saving, setSaving]       = useState(false);
const [tab, setTab]             = useState(“day”);

const todayStr = today();
const myMinutes = userData?.scores?.[todayStr] ?? null;
const myTier    = myMinutes !== null ? tier(myMinutes) : null;

const sorted = […members]
.map(m => ({…m, minutes: m.scores?.[todayStr] ?? null}))
.filter(m => m.minutes !== null)
.sort((a,b) => a.minutes - b.minutes);

const myRank  = sorted.findIndex(m=>m.uid===user.uid) + 1;
const above   = myRank > 1 ? sorted[myRank-2] : null;
const last    = sorted[sorted.length-1];

async function saveMinutes() {
const m = parseInt(inputVal);
if (isNaN(m) || m < 0 || m > 1440) { onToast(“⚠️ Ungültige Zahl”); return; }
setSaving(true);
try {
const scores = {…(userData?.scores||{}), [todayStr]: m};
// update streak
const yesterday = new Date(Date.now()-86400000).toISOString().slice(0,10);
const hadYesterday = userData?.scores?.[yesterday] !== undefined;
const streak = hadYesterday ? (userData?.streak||0)+1 : 1;
await updateDoc(doc(db,“users”,user.uid),{scores, streak});
setShowInput(false);
setInputVal(””);
onToast(“✓ Gespeichert!”);
} catch(e){ onToast(“Fehler: “+e.message); }
setSaving(false);
}

