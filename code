function AuthScreen({onAuth}) {
const [mode, setMode]     = useState(“login”); // login | register
const [name, setName]     = useState(””);
const [email, setEmail]   = useState(””);
const [pw, setPw]         = useState(””);
const [err, setErr]       = useState(””);
const [loading, setLoad]  = useState(false);

async function handleSubmit() {
setErr(””); setLoad(true);
try {
if (mode === “register”) {
if (!name.trim()) { setErr(“Bitte Namen eingeben”); setLoad(false); return; }
const cred = await createUserWithEmailAndPassword(auth, email, pw);
await updateProfile(cred.user, {displayName: name.trim()});
await setDoc(doc(db,“users”,cred.user.uid), {
name: name.trim(),
username: name.trim().toLowerCase().replace(/\s+/g,”_”),
email, streak:0, badges:[],
createdAt: serverTimestamp(),
});
onAuth(cred.user);
} else {
const cred = await signInWithEmailAndPassword(auth, email, pw);
onAuth(cred.user);
}
} catch(e) {
const msgs = {
“auth/email-already-in-use”:“E-Mail bereits registriert”,
“auth/invalid-email”:“Ungültige E-Mail”,
“auth/weak-password”:“Passwort zu kurz (min. 6 Zeichen)”,
“auth/user-not-found”:“Kein Account mit dieser E-Mail”,
“auth/wrong-password”:“Falsches Passwort”,
“auth/invalid-credential”:“E-Mail oder Passwort falsch”,
};
setErr(msgs[e.code] || e.message);
}
setLoad(false);
}

